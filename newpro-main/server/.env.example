PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.jvapwqi.mongodb.net/jobconnect?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
NODE_ENV=development
CLIENT_URL=http://localhost:5173
